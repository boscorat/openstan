<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    allow-unsigned-executable-memory is required for PyQt6 / Python to run
    under Apple's hardened runtime (--options runtime), which is mandatory
    for notarisation.  Without this entitlement the app crashes at launch
    under the hardened runtime because the Python interpreter and Qt JIT
    need to map executable memory pages.
  -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
